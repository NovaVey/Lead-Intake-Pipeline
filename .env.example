# Copy this file to .env and fill in real values for your environment.
# Never commit the real .env file.

# Local dev only — Railway (and most hosts) inject their own PORT at
# runtime, which the app already reads via process.env.PORT.
PORT=3000

# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# The database must exist and be reachable before running `npm run db:init`.
# In production this is set directly as a Railway service variable
# (dashboard -> Variables tab), never committed — see the Deployment
# section in README.md.
DATABASE_URL=postgresql://user:password@localhost:5432/lead_intake
